---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Riccardo Fracchioni">

  <section class="hero">

    <div class="hero-text">

      <p class="eyebrow">
        Philosophy of AI · Philosophy of Science
      </p>

      <h1>Riccardo Fracchioni</h1>

      <p class="intro">
        I am a philosopher working on artificial intelligence,
        machine learning, and scientific understanding.
        My research focuses on the epistemological implications
        of AI-based methods in science and the assessment of
        semantic competence in large language models.
      </p>

      <div class="hero-links">
        <a href="/research">Research</a>
        <a href="/publications">Publications</a>
        <a href="/cv">Curriculum Vitae</a>
        <a href="/contact">Contact</a>
      </div>

    </div>

    <div class="hero-image">
      <img
        src="/images/profile.jpeg"
        alt="Portrait of Riccardo Fracchioni"
      />
    </div>

  </section>

  <section class="research-interests">

    <p class="section-label">Research</p>

    <h2>Research interests</h2>

    <div class="interest-grid">

      <article>
        <h3>AI and scientific understanding</h3>
        <p>
          How AI-based methods contribute to explanation,
          prediction, and knowledge production in science.
        </p>
      </article>

      <article>
        <h3>Machine learning epistemology</h3>
        <p>
          The epistemic significance of successful and failed
          machine-learning predictions.
        </p>
      </article>

      <article>
        <h3>Language models</h3>
        <p>
          Semantic competence, representation, and understanding
          in large language models.
        </p>
      </article>

      <article>
        <h3>Scientific explanation</h3>
        <p>
          Models, causality, prediction, and explanatory understanding.
        </p>
      </article>

    </div>

  </section>

</Layout>