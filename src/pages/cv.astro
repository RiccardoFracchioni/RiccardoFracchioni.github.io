            </a>
          </p>
        </article>

        <article class="reference-entry">
          <h3>Jan Sprenger</h3>
          <p>
            <a href="mailto:jan.sprenger@unito.it">
              jan.sprenger@unito.it
            </a>
          </p>
        </article>
      </section>

    </div>

  </div>

</Layout>